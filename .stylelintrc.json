{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": ["theme", "utility", "variant", "custom-variant", "source", "config"]
      }
    ],
    "import-notation": "string",
    "hue-degree-notation": "number",
    "property-no-vendor-prefix": null
  }
}
