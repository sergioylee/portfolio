---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import { site } from "../data/site";
import serifRegular from "@fontsource/ibm-plex-serif/files/ibm-plex-serif-latin-400-normal.woff2?url";
import serifBold from "@fontsource/ibm-plex-serif/files/ibm-plex-serif-latin-700-normal.woff2?url";
import monoRegular from "@fontsource/ibm-plex-mono/files/ibm-plex-mono-latin-400-normal.woff2?url";

const {
  title = site.name,
  description = `Welcome to ${site.name}'s portfolio`,
  ogImage = "/og.png",
  robots = "index, follow",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const NAV_LINKS = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/work", label: "Work" },
  { href: "/blog", label: "Blog" },
  { href: "/contact", label: "Contact" },
];

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      crossorigin
      fetchpriority="high"
      href={serifRegular}
    />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={serifBold} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={monoRegular} />
    <meta name="description" content={description} />
    <meta name="keywords" content="Sergio Lee, Sergio Y Lee, Sergio Y. Lee, yergios" />
    <meta name="author" content={site.name} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content={site.name} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
      const THEMES = ["dark", "light"];
      const DEFAULT_THEME = THEMES[0];

      function applyTheme() {
        const theme = localStorage.theme || DEFAULT_THEME;
        document.documentElement.classList.remove(...THEMES);
        document.documentElement.classList.add(theme);
      }

      document.addEventListener("astro:after-swap", applyTheme);
      applyTheme();
    </script>
  </head>
  <body>
    <div class="min-h-screen bg-background">
      <div class="mx-auto max-w-column px-6 py-12 md:py-16">
        <header class="mb-12">
          <div class="flex items-center justify-between mb-4">
            <span class="font-serif font-medium text-lg text-foreground">{site.name}</span>
            <button
              id="change-theme-btn"
              class="font-mono text-sm text-muted-foreground cursor-pointer hover:text-foreground"
              aria-label="Toggle theme"
              title="Change theme"
            ></button>
          </div>
          <nav aria-label="Main navigation">
            <ul class="flex flex-wrap gap-x-4 sm:gap-x-6 gap-y-1 list-none p-0 m-0">
              {
                NAV_LINKS.map(({ href, label }) => {
                  const isActive = pathname === href;
                  return (
                    <li class="m-0">
                      <a
                        href={href}
                        class={
                          isActive
                            ? "no-underline font-serif text-foreground font-medium cursor-default"
                            : "font-serif text-accent hover:text-secondary"
                        }
                        aria-current={isActive ? "page" : undefined}
                      >
                        {label}
                      </a>
                    </li>
                  );
                })
              }
            </ul>
          </nav>
        </header>

        <main>
          <slot />
        </main>

        <footer class="mt-16 pt-8 border-t border-border">
          <p class="font-mono text-sm text-muted-foreground m-0">
            &copy; {year}
            {site.name}
          </p>
        </footer>
      </div>
    </div>
  </body><script>
    const THEMES = ["dark", "light"];
    const DEFAULT_THEME = THEMES[0];

    function setupThemeToggle() {
      const btn = document.getElementById("change-theme-btn");
      if (!btn) return;

      function syncButton(theme) {
        const target = THEMES.find((t) => t !== theme);
        btn.setAttribute("aria-label", `Switch to ${target} theme`);
      }

      syncButton(localStorage.theme || DEFAULT_THEME);

      btn.addEventListener("click", () => {
        const newTheme = THEMES.find((t) => t !== (localStorage.theme || DEFAULT_THEME));
        localStorage.theme = newTheme;
        document.documentElement.classList.remove(...THEMES);
        document.documentElement.classList.add(newTheme);
        syncButton(newTheme);
      });
    }

    document.addEventListener("astro:after-swap", setupThemeToggle);
    setupThemeToggle();
  </script>
</html>
