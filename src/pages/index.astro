---
import { getCollection } from "astro:content";
import { projects } from "../data/projects";
import { site } from "../data/site";
import Layout from "../layouts/Layout.astro";

const recentPosts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .slice(0, 5);

const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: site.name,
  url: Astro.site?.toString(),
  email: `mailto:${site.email}`,
  jobTitle: "Software Engineer",
  sameAs: [
    `https://github.com/${site.github}`,
    `https://linkedin.com/in/${site.linkedin}`,
  ],
};
---

<Layout title={site.name}>
  <h1 class="font-serif text-foreground mb-1">{site.name}</h1>
  <p class="font-mono text-sm text-muted-foreground mb-10">
    Software Engineer
  </p>

  <p>
    I write software for a living. My background is in hardware though: electronics engineering
    and building custom PCs in Buenos Aires. At some point I traded screwdrivers for
    keyboards and never looked back (maybe from time to time).
  </p>
  <p>
    I care about the software I write and the businesses I work for. I try to keep things
    simple, correct, and conscious about the metal underneath. I've worked across the stack
    in small teams, taken ownership from start to finish of projects, and led through the kind of
    restructuring that makes everyone nervous: from legacy job-security services nobody wanted to
    touch, to over-complicated fancy corporate architectures.
  </p>
  <p>
    I appreciate software that is open, transparent, and fair with its users. Fast is non-negotiable,
    minimal, private, and built to last. The old-school kind.
  </p>
  <p>
  This site is a record of what I've built and where I stand. No buzzwords and no AI, pinky promise.
  </p>

  <hr />

  <section>
    <h2 class="font-serif mb-4">Recent work</h2>
    <ul>
      {projects.slice(0, 5).map((project) => (
        <li>
          <a href={`/work#${project.id}`}>{project.title}</a>
          <span class="font-mono text-sm text-muted-foreground ml-2">{project.date}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="mt-10">
    <h2 class="font-serif mb-4">Recent writing</h2>
    <ul>
      {recentPosts.map((post) => (
        <li>
          <a href={`/blog/${post.id.replace(/\.md$/, "")}`}>{post.data.title}</a>
          <span class="font-mono text-sm text-muted-foreground ml-2">{post.data.date}</span>
        </li>
      ))}
    </ul>
  </section>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
</Layout>
