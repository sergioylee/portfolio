---
import { getCollection } from "astro:content";
import { projects } from "../data/projects";
import { site } from "../data/site";
import Layout from "../layouts/Layout.astro";

const recentPosts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .slice(0, 5);

const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: site.name,
  alternateName: ["Sergio Lee", "Sergio Y Lee", "yergios"],
  url: Astro.site?.toString(),
  email: `mailto:${site.email}`,
  jobTitle: "Software Engineer",
  sameAs: [
    `https://github.com/${site.github}`,
    `https://codeberg.org/${site.codeberg}`,
    `https://x.com/${site.x}`,
    `https://mastodon.social/@${site.mastodon}`,
  ],
};
---

<Layout title={site.name}>
  <h1 class="font-serif text-foreground mb-1">{site.name}</h1>
  <p class="font-mono text-sm text-muted-foreground mb-10">
    Software Engineer
  </p>

  <p>
    I build software for a living, currently focusing on web platform development. My sights are
    set on going deeper into the stack. With a background in electronics engineering from the
    University of Buenos Aires and a self-taught path in computer science, I approach my work with
    both technical rigor and genuine enjoyment.
  </p>
  <p>
    I’ve worked across the stack in small teams, taking full ownership of projects from
    conception to delivery. My experience ranges from shipping code used by thousands of users to
    navigating everything from legacy systems no one wanted to touch to the complexities of
    over-engineered corporate architectures.
  </p>
  <p>
    To me, writing software is more than just code, it's a craft. I care about what I build,
    striving for simplicity, correctness, and a touch of elegance. I'm mindful of the hardware
    beneath and believe the best solutions are thoughtful, efficient, and even beautiful.
  </p>

  <hr />

  <section>
    <h2 class="font-serif mb-4">Recent work</h2>
    <ul>
      {projects.slice(0, 5).map((project) => (
        <li>
          <a href={`/work#${project.id}`}>{project.title}</a>
          <span class="font-mono text-sm text-muted-foreground ml-2">{project.date}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="mt-10">
    <h2 class="font-serif mb-4">Recent writing</h2>
    <ul>
      {recentPosts.map((post) => (
        <li>
          <a href={`/blog/${post.id.replace(/\.md$/, "")}`}>{post.data.title}</a>
          <span class="font-mono text-sm text-muted-foreground ml-2">{post.data.date}</span>
        </li>
      ))}
    </ul>
  </section>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
</Layout>
