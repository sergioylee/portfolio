---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../config";

const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: SITE.name,
  url: Astro.site?.toString(),
  email: `mailto:${SITE.email}`,
  jobTitle: "Software Engineer",
  sameAs: [
    `https://github.com/${SITE.github}`,
    `https://linkedin.com/in/${SITE.linkedin}`,
  ],
};
---

<Layout title={`${SITE.name}`}>
  <h1 class="font-serif text-foreground mb-1">{SITE.name}</h1>
  <p class="font-mono text-sm text-muted-foreground mb-10">
    Software Engineer &mdash; {SITE.location}
  </p>

  <p>
    I write software for a living. My background is in hardware though, electronics engineering
    and building custom PCs in Buenos Aires. At some point I traded screwdrivers for
    keyboards and never looked back (maybe from time to time).
  </p>
  <p>
    I care about the software I write and the businesses I work for. I try to keep things
    simple, correct, and conscious about the metal underneath. I've worked across the stack
    in small teams, taken ownership from start to finish, and led through the kind of
    restructuring that makes everyone nervous: from legacy WCF services nobody wanted to
    touch, to fancy corporate architectures.
  </p>
  <p>
    I appreciate software that is open, transparent, and honest with its users. Fast,
    minimal, private, and built to last. The old-school kind.
  </p>
  <p>
    This site is a record of what I've built and where I stand. No buzzwords, no crap, no AI.
  </p>

  <hr />

  <section>
    <h2 class="font-serif mb-4">Recent work</h2>
    <ul>
      <li>
        <a href="/work#raft">Distributed key-value store with Raft consensus</a>
        <span class="font-mono text-sm text-muted-foreground ml-2">2024</span>
      </li>
    </ul>
  </section>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</Layout>
