---
import { site } from "../data/site";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title={`Privacy Policy — ${site.name}`}
  description={`Privacy policy for ${site.name}'s personal website.`}
  robots="noindex, follow"
>
  <h1 class="font-serif mb-2">Privacy Policy</h1>
  <p class="text-muted-foreground font-mono text-sm mb-10">Last updated: April 2026</p>

  <p>
    This site sets no cookies and collects no personal data. Anonymous, aggregated traffic metrics
    (page views, country, browser type) are measured via <a
      href="https://www.cloudflare.com/web-analytics/"
      target="_blank"
      rel="noopener noreferrer">Cloudflare Web Analytics</a
    >, which cannot identify individual visitors.
  </p>
  <p>
    This site is compliant with the GDPR, UK GDPR, PECR, CCPA/CPRA, and the ePrivacy Directive.
    Questions: <a href={`mailto:${site.email}`}>{site.email}</a>.
  </p>
</Layout>
