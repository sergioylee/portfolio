---
import { site } from "../data/site";
import Layout from "../layouts/Layout.astro";
---

<Layout title={`Contact — ${site.name}`} description=`Get in touch with ${site.name}.`>
  <h1 class="font-serif mb-10">Contact</h1>

  <p>You can reach me by email or through any of the links below.</p>

  <section>
    <dl class="space-y-4">
      <div class="flex gap-4 items-baseline">
        <dt class="font-mono text-sm text-muted-foreground w-20 shrink-0">Email</dt>
        <dd class="m-0">
          <a href={`mailto:${site.email}`}>{site.email}</a>
        </dd>
      </div>
      <div class="flex gap-4 items-baseline">
        <dt class="font-mono text-sm text-muted-foreground w-20 shrink-0">GitHub</dt>
        <dd class="m-0">
          <a href={`https://github.com/${site.github}`} target="_blank" rel="noopener noreferrer">
            github.com/{site.github}
          </a>
        </dd>
      </div>
      <div class="flex gap-4 items-baseline">
        <dt class="font-mono text-sm text-muted-foreground w-20 shrink-0">Codeberg</dt>
        <dd class="m-0">
          <a
            href={`https://codeberg.org/${site.codeberg}`}
            target="_blank"
            rel="noopener noreferrer"
          >
            codeberg.org/{site.codeberg}
          </a>
        </dd>
      </div>
      <div class="flex gap-4 items-baseline">
        <dt class="font-mono text-sm text-muted-foreground w-20 shrink-0">Mastodon</dt>
        <dd class="m-0">
          <a
            href={`https://mastodon.social/@${site.mastodon}`}
            target="_blank"
            rel="noopener noreferrer"
          >
            mastodon.social/@{site.mastodon}
          </a>
        </dd>
      </div>
      <div class="flex gap-4 items-baseline">
        <dt class="font-mono text-sm text-muted-foreground w-20 shrink-0">X</dt>
        <dd class="m-0">
          <a href={`https://x.com/${site.x}`} target="_blank" rel="noopener noreferrer">
            x.com/{site.x}
          </a>
        </dd>
      </div>
    </dl>
  </section>
</Layout>
