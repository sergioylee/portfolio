---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact — Sergio Y. Lee" description="Get in touch with Sergio Y. Lee.">
  <h1 class="font-serif mb-10">Contact</h1>

  <p>
    I'm not looking for work right now, but I'm happy to talk about interesting technical
    problems. I respond to emails that get to the point.
  </p>

  <hr />

  <section>
    <dl class="space-y-4">
      <div class="flex gap-4 items-baseline">
        <dt class="font-mono text-sm text-muted-foreground w-20 shrink-0">Email</dt>
        <dd class="m-0">
          <a href="mailto:you@example.com">you@example.com</a>
        </dd>
      </div>
      <div class="flex gap-4 items-baseline">
        <dt class="font-mono text-sm text-muted-foreground w-20 shrink-0">GitHub</dt>
        <dd class="m-0">
          <a href="https://github.com/yourhandle" target="_blank" rel="noopener noreferrer">
            github.com/yourhandle
          </a>
        </dd>
      </div>
      <div class="flex gap-4 items-baseline">
        <dt class="font-mono text-sm text-muted-foreground w-20 shrink-0">LinkedIn</dt>
        <dd class="m-0">
          <a href="https://linkedin.com/in/yourhandle" target="_blank" rel="noopener noreferrer">
            linkedin.com/in/yourhandle
          </a>
        </dd>
      </div>
    </dl>
  </section>

  <hr />

  <p class="text-muted-foreground text-sm">
    I don't use Twitter, Discord, or any other real-time chat platform for professional
    communication. Email only.
  </p>
</Layout>
